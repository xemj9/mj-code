# MJ Code Configuration via Environment Variables
# Copy this file to .env and fill in your values

# Required: Your LLM API key
OPENAI_API_KEY=sk-your-key-here

# Optional: Override provider, model, base URL
# MJ_CODE_PROVIDER=openai-compatible
# MJ_CODE_MODEL=gpt-4o
# MJ_CODE_BASE_URL=https://api.openai.com/v1

# Optional: Network mode (off|docs-only|open-web)
# MJ_CODE_NETWORK_MODE=open-web

# Optional: Web search provider (fallback|brave)
# fallback = DuckDuckGo (no API key needed)
# brave = Brave Search API (requires API key)
# MJ_CODE_WEB_PROVIDER=fallback

# Optional: Brave Search API key (only needed if webProvider=brave)
# MJ_CODE_WEB_PROVIDER_API_KEY=

# Optional: Permission mode (read-only|workspace-write|full-access)
# MJ_CODE_PERMISSION_MODE=workspace-write
